{
  "name": "@luisrodrigues/nestjs-scheduler-dashboard",
  "version": "0.0.1",
  "description": "Dashboard for @nestjs/schedule — embedded UI, job history, metrics, stop/trigger controls",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @luisrodrigues/nestjs-scheduler-dashboard-ui build",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/schedule": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "keywords": [
    "nestjs",
    "scheduler",
    "cron",
    "job",
    "dashboard",
    "monitoring"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luisrodrigues/nestjs-scheduler-dashboard"
  }
}
