{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "outDir": "./dist",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@nestjs-scheduler-dash/scheduler-dash": ["../../packages/scheduler-dash/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
